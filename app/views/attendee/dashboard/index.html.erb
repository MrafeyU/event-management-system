<div class="container my-4">
<h2 class="mb-4 fw-bold">Attendee Dashboard</h2>

  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="card shadow-sm border-0 text-center p-3" style="background-color: #fde863">
        <h6 class="text-muted">Your Bookings</h6>
        <h2 class="fw-bold"><%= @bookings.count %></h2>
      </div>
    </div>
  </div>


  <div class="card shadow-sm border-0 p-4 mb-4">
    <h5 class="mb-3">Explore</h5>
    <div class="d-flex gap-2">
      <%= link_to "Browse Events", events_path, class: "btn btn-outline-primary" %>
      <%= link_to "My Bookings", bookings_path, class: "btn btn-outline-primary" %>
    </div>
  </div>


  <div class="card shadow-sm border-0 p-4 mb-5">
    <h5 class="mb-3">Recent Bookings</h5>


    <% @bookings.each do |booking| %>
      <div class="d-flex justify-content-between border-bottom py-2">
        <span><%= link_to booking.event.title, booking %></span>
        <span class="text-muted">Seats: <%= booking.seats_booked %></span>
      </div>
    <% end %>
  </div>




</div>