<div class="container my-4">
<% content_for :title, "Users" %>

<h1>Users</h1>

<div id="users" >
  <% @users.each do |user| %>
    <div class="card mb-2 shadow-sm">
        <%= render partial: "admin/users/user", locals: { user: user }%>
        <div class="px-2"><%= link_to "Show this user", admin_user_path(user), class: "btn btn-primary" %></p></div>
    </div>
  <% end %>
</div>

<%= link_to "New user", new_admin_user_path, class: "btn btn-primary" %>
