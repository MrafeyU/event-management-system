<%if current_user.is_a?(Admin)%>
  <div class="container my-4">
    <div class="card mb-2 shadow-sm">
      <%= render partial: "admin/users/user", locals: { user: @user }%>
      <div class="btn-group mb-2 px-2" role="group" aria-label="Basic example">
        <div class="px-1 py-2">
          <%= link_to "Back to Users", admin_users_path, class: "btn btn-sm btn-outline-primary"%>
        </div>
        <div class="px-1 py-2">
          <%= link_to "Edit User details", edit_admin_user_path(@user), class: "btn btn-sm btn-outline-primary"%>
        </div>
        <div class="px-1 py-2">
          <%= button_to "Delete", admin_user_path(@user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
        </div>
      </div>
    </div>
  </div>
<%end%>
