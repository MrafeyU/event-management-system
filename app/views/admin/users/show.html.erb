<%if current_user.is_a?(Admin)%>
<div class="container my-4">
    <div class="card mb-2 shadow-sm">
    <%= render partial: "admin/users/user", locals: { user: @user }%>
    <div class="px-2 py-2">
    <%= link_to "Back to Users", admin_users_path, class: "btn btn-primary"%>
    </div>
    <div class="px-2 py-2">
    <%= link_to "Edit User details", edit_admin_user_path(@user), class: "btn btn-primary"%>
    </div>
</div>
<%end%>

