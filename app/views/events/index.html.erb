<div class="container my-4">
  <p style="color: green"><%= notice %></p>
  <h1>Events</h1>
  <% content_for :title, "Events" %>
<div class="card shadow-sm border-1 text-center p-3 mb-4">
  <%# Form for search bar..%>
  <%= form_with(url: events_path, method: "GET", data: { controller: "search", turbo_frame: "events", turbo_action: "advance" }) do |form| %>
    <%= form.label :query, "Search by name:" %>
    <%= form.text_field :query, data: { action: "input->search#search" }, class: "form-control"%>
    <div class="mb-3">
        Filter by:
        <%= form.date_field :date, value: params[:date], class: "form-control" %>
        </div>
      <div class="mb-3">
      <%= form.submit "Filter", class: "btn btn-outline-primary"%>
      <%= link_to "Clear", events_path, class: "btn btn-outline-primary" %>
      </div>
  <% end %>
</div>

  <%# Rendering events through event display partial%>
  <div class="container">
    <%= render "events", events: @events %>
  </div>



  <div class="mt-3 d-flex gap-2">
    <% if policy(Event.new).new? %>
      <%= link_to "New event", new_event_path, class: "btn btn-primary" %>
    <% end %>
  </div>

</div>  