<div class="container my-4">
  <p style="color: green"><%= notice %></p>
  <h1>Events</h1>
  <% content_for :title, "Events" %>
  <div class="card  text-center px-4 py-2 mb-4">
    <%# Form for search bar..%>
    <%= form_with(url: events_path, method: "GET", data: { controller: 'form-submission', turbo_frame: "events", turbo_action: "advance" }) do |form| %>
      <div class="row">
        <div class="col">
          <%form.label :query,  %>
          <%= form.text_field :query, data: { action: "input->form-submission#search" }, class: "form-control", placeholder: "Search by title:", style:"width: 49vw;"%>
        </div>
        <div class="col">
          <%= form.date_field :date, value: params[:date], class: "form-control", style:"width: 10vw;"%>
        </div>
        <div class="col py-1" , style="width: 21vw;">
          <%= form.submit "Filter", class: "btn btn-sm btn-outline-primary"%>
          <%= link_to "Clear", events_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    <% end %>
  </div>
  <%# Rendering events through event display partial%>
  <div class="container">
    <%= render "events", events: @events %>
  </div>
  <div class="mt-3 d-flex gap-2">
    <%= paginate @events %>
  </div>
  <div class="mt-3 d-flex gap-2">
    <% if policy(Event.new).new? %>
      <%= link_to "New event", new_event_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
  