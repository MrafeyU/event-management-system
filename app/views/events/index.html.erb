<div class="container my-4">
  <p style="color: green"><%= notice %></p>

  <% content_for :title, "Events" %>
  <h1>Events</h1>
    <div id="events">
      <% @events.each do |event| %>
        <%= render event %>
      <% end %>
      <div class="mt-3 d-flex gap-2">


    </div>

    <div class="mt-3 d-flex gap-2">
      <%= link_to "New event", new_event_path, class: "btn btn-primary" %>
    </div>
</div>  