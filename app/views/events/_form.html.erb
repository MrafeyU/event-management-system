<%= form_with(model:  event,class: "p-3 border rounded bg-light") do |form| %>
  <% if event.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>
      <ul>
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
   <% end %>

    <%= form.text_field :user_id, value: current_user.id, style: "display:none;" if current_user %> <br>

    <div class="mb-3">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, class: "form-control" %>    
    </div>
    <div class="mb-3">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, class: "form-control" %>
    </div>
    <div class="mb-3">
        <%= form.label :event_date, class: "form-label" %>
        <%= form.date_field :event_date, class: "form-control" %>
    </div>      
    <div class="mb-3">
        <%= form.label :location, class: "form-label" %>
        <%= form.text_field :location, class: "form-control" %>
    </div>
    <div class="mb-3">
        <%= form.label :total_seats, class: "form-label" %>
        <%= form.number_field :total_seats, class: "form-control" %>
    </div>
    <div class="mb-3">
        <%= form.label :vip_seat_price, class: "form-label" %>
        <%= form.number_field :vip_seat_price, step: 0.01, class: "form-control" %>
    </div>  
    <div class="mb-3">
        <%= form.label :standard_seat_price, class: "form-label" %>
        <%= form.number_field :standard_seat_price, step: 0.01, class: "form-control" %>
    </div>
    <div class="mb-3">
        <%= form.label :economy_seat_price, class: "form-label" %>
        <%= form.number_field :economy_seat_price, step: 0.01, class: "form-control" %>
    </div>  



    <% if current_user.is_a?(Admin) %>
    <div class="mb-3">
        <%= form.label :user_id, class: "form-label" %>
        <%= form.collection_select :user_id, Organizer.all, :id, :name, prompt: "Select Organizer", class: "form-select" %>
    </div>
    <% elsif current_user.is_a?(Organizer) %>
    <div class="mb-3">
         <% form.label :user_id, class: "form-label" %>
         <% form.text_field :user_id, value: current_user.id, readonly: true, class: "form-control" %>    
    </div>
    <% end %>   



  <div class="mb-3">
    <%= form.label :images, style: "display: block" %>
    <%= form.file_field :images, multiple: true %>
    <% if event.images.attached? %>
    <h4>Current Images</h4>
        <% event.images.each do |image| %>
          <div>
            <%= image_tag image, width: 150 if image.image? %>

            <%= link_to "Remove",
                remove_images_events_path(attachment_id: image.id),
                data: { turbo_method: :delete, turbo_confirm: "Remove this image?" } %>
          </div>
        <% end %>
      <% end %>
</div>
  
  <div>
    <%= form.submit %>
  </div>
<% end %>
