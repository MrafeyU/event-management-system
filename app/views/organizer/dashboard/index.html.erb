<div class="container my-4">
<h1>Organizer Dashboard</h1>

  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="card shadow-sm border-0 text-center p-3"style="background-color: #f3fd635b">
        <h6 class="text-muted">Your Events</h6>
        <h2 class="fw-bold"><%= @events.count %></h2>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm border-0 text-center p-3"style="background-color: #b8fd635b">
        <h6 class="text-muted">Total Bookings</h6>
        <h2 class="fw-bold"><%= @total_bookings %></h2>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 p-4 mb-4">
    <h5 class="mb-3">Your Actions</h5>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Create Event", new_event_path, class: "btn btn-outline-primary" %>
      <%= link_to "My Events", events_path, class: "btn btn-outline-primary" %>
      <%= link_to "Bookings", bookings_path, class: "btn btn-outline-primary" %>
    </div>
  </div>

  <div class="card shadow-sm border-0 p-4">
    <h5 class="mb-3">Your Events</h5>
    <% @events.each do |event| %>
      <div class="d-flex justify-content-between align-items-center border-bottom py-2">
        <span><%= event.title %></span>
        <%= link_to "View", event_path(event), class: "btn btn-sm btn-outline-dark" %>
      </div>
    <% end %>
  </div>


</div>